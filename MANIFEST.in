include CHANGELOG
include LICENSE
include README.rst
include MANIFEST.in
include CONTRIBUTING.md
include .pre-commit-config.yaml
include libqtile/backend/wayland/proto/*.xml
include libqtile/backend/wayland/qw/*.h
include libqtile/backend/wayland/qw/*.c
include builder.py
include conftest.py

recursive-include libqtile/backend/macos *.c
recursive-include libqtile/backend/macos *.h
recursive-include libqtile/backend/macos *.m

exclude .dockerignore
exclude Dockerfile.test
exclude deps
exclude install-deps
exclude install-qtile
exclude run-all-tests
exclude run-coverage
exclude run-macos-tests
exclude run-wl-tests
exclude run-x11-tests
exclude plan.md
exclude plan-update.md
exclude .coveragerc

prune todos
exclude .pylintrc
exclude flake.nix
exclude flake.lock
exclude nix/*
exclude uv.lock
exclude libqtile/_ffi*.py
exclude libqtile/backend/x11/_ffi*.py
exclude libqtile/backend/wayland/_ffi*.*
exclude libqtile/backend/wayland/_libinput*.*
exclude libqtile/backend/wayland/qw/build/*.o
exclude Makefile
exclude .readthedocs.yaml
exclude .git-blame-ignore-revs
exclude .clang-format

graft libqtile/resources
graft libqtile/widget/helpers
graft resources
graft test
recursive-include libqtile *.typed

prune bin
prune docs
prune scripts
prune rpm

recursive-exclude * __pycache__
recursive-exclude * *.py[co]
recursive-exclude stubs *
