#!/usr/bin/env bash

set -ex

# 1. Environment Setup
CACHE_DIR="${AGENT_TOOLSDIRECTORY:-/tmp}/qtile-deps"
WAYLAND_CACHE="$CACHE_DIR/wayland"
# Ephemeral runners need libraries installed into the persistent PVC
INSTALL_DIR="${WAYLAND_INSTALL_DIR:-$WAYLAND_CACHE/install}"

mkdir -p "$WAYLAND_CACHE"
mkdir -p "$INSTALL_DIR"

# Ensure pkg-config looks into our PVC
export PKG_CONFIG_PATH="$INSTALL_DIR/lib/pkgconfig:$INSTALL_DIR/share/pkgconfig:$PKG_CONFIG_PATH"

# 2. Fast Skip Check (No Lock)
# We do this BEFORE waiting for the lock to unblock parallel runners instantly
UPSTREAM_URL="https://raw.githubusercontent.com/qtile/qtile/refs/heads/master/scripts/ubuntu_wayland_setup"
TEMP_SETUP=$(mktemp /tmp/wayland_setup.XXXXXX)
wget -qO "$TEMP_SETUP" "$UPSTREAM_URL"

# shellcheck disable=SC1090
source <(grep -E "^[A-Z_]+=[0-9.]+" "$TEMP_SETUP")

ALL_PRESENT=1
pkg-config --atleast-version="$WAYLAND" wayland-client || ALL_PRESENT=0
pkg-config --atleast-version="$WLROOTS" "wlroots-$(echo "$WLROOTS" | cut -d. -f1,2)" || ALL_PRESENT=0

# Check for Xwayland in either /usr/bin or our PVC
if [ -f "/usr/bin/Xwayland" ]; then
    echo "Xwayland found in /usr/bin"
elif [ -f "$INSTALL_DIR/bin/Xwayland" ]; then
    echo "Xwayland found in PVC, creating symlink..."
    sudo ln -sf "$INSTALL_DIR/bin/Xwayland" /usr/bin/Xwayland
else
    ALL_PRESENT=0
fi

if [ "$ALL_PRESENT" -eq 1 ]; then
    echo "All foundation dependencies satisfied in $INSTALL_DIR. skipping lock and build."
    rm -f "$TEMP_SETUP"
    exit 0
fi

# 3. Acquire Atomic Lock (Only if we actually need to build)
LOCK_DIR="$WAYLAND_CACHE/global_install.lock"

cleanup() {
    rm -rf "$LOCK_DIR"
    rm -f "$TEMP_SETUP"
}
trap cleanup EXIT

acquire_lock() {
    local start_time
    start_time=$(date +%s)

    while ! mkdir "$LOCK_DIR" 2>/dev/null; do
        # Check if lock is stale (older than 30 mins)
        if [ -d "$LOCK_DIR" ] && [ "$(( $(date +%s) - $(stat -c %Y "$LOCK_DIR") ))" -gt 1800 ]; then
            echo "Removing stale lock $LOCK_DIR"
            rm -rf "$LOCK_DIR"
            continue
        fi
        echo "Waiting for global install lock ($LOCK_DIR)..."
        sleep $(( (RANDOM % 10) + 5 ))

        if [ $(($(date +%s) - start_time)) -gt 3600 ]; then
            echo "Timed out waiting for lock"
            exit 1
        fi
    done
}

acquire_lock

# 4. Standard OS Updates
OS_RELEASE=$(grep -oP '(?<=^ID=).+' /etc/os-release | tr -d '"')
case "$OS_RELEASE" in
ubuntu)
  sudo apt -y update && sudo apt -y install software-properties-common
  sudo add-apt-repository -y universe && sudo add-apt-repository -y multiverse
  ;;
debian)
  sudo apt -y update
  ;;
esac
sudo apt -y upgrade
sudo apt -y install "$@"

# 5. Patch and Execute Setup Script
PATCHED_SETUP=$(mktemp /tmp/wayland_setup_patched.XXXXXX)
sed -i "s|mkdir -p cache|cache=\"$WAYLAND_CACHE\"; mkdir -p \"\$cache\"; cd \"\$cache\"|g" "$TEMP_SETUP"
sed -i "s|--prefix=/usr|--prefix=\"$INSTALL_DIR\"|g" "$TEMP_SETUP"
# shellcheck disable=SC2016
sed -i 's|if \[ -f "cache/\$filename" \];|if [ -f "$filename" ];|g' "$TEMP_SETUP"
sed -i 's|wget -P cache|wget -P .|g' "$TEMP_SETUP"
sed -i 's|"cache/|"./|g' "$TEMP_SETUP"

# Use the python helper for granular safety within the script itself
cp "$TEMP_SETUP" "$PATCHED_SETUP"
sed -i "s|meson setup build|meson setup build -Dwerror=false|g" "$PATCHED_SETUP"

bash "$PATCHED_SETUP"
rm -f "$PATCHED_SETUP"

# Final Xwayland check and symlink
if [ -f "$INSTALL_DIR/bin/Xwayland" ] && [ ! -f "/usr/bin/Xwayland" ]; then
    sudo ln -sf "$INSTALL_DIR/bin/Xwayland" /usr/bin/Xwayland
fi

sudo ldconfig
